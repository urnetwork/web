---
import Base from '../../../layouts/Base.astro';
import DocsIsland from '../../../islands/DocsIsland.jsx';
import { NON_EN_LANGS, LANGS } from '../../../lib/i18n.js';

export function getStaticPaths() {
    return NON_EN_LANGS.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const dir = LANGS[lang]?.dir || 'ltr';
---
<Base title="Docs — URnetwork" lang={lang} dir={dir}>
    <DocsIsland activeRoute="docs" client:load />
</Base>
