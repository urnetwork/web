---
import Base from '../layouts/Base.astro';
import DisclaimerStatic from '../components/DisclaimerStatic.astro';
import Section from '../components/Section.astro';
import WhitepaperClauses from '../components/WhitepaperClauses.astro';
import FooterStatic from '../components/FooterStatic.astro';
import HeroIsland from '../islands/HeroIsland.jsx';
import NetworkDiagram from '@react/components/NetworkDiagram.jsx';
import en from '@react/i18n/en.js';

const t = en;
---
<Base title="$UR — Own your privacy. Own your network." lang="en">
    <div class="app">
        <DisclaimerStatic />
        <HeroIsland client:load />

        <main>
            <Section id="whitepaper" eyebrow={t.whitepaper.eyebrow} title={t.whitepaper.title} variant="whitepaper">
                <NetworkDiagram client:load active="subnet" lang="en" />
                <WhitepaperClauses clauses={t.whitepaper.clauses} source={t.whitepaper.source} />
            </Section>
        </main>

        <FooterStatic t={t} lang="en" />
    </div>
</Base>
