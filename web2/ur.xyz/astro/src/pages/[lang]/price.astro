---
import Base from '../../layouts/Base.astro';
import DisclaimerStatic from '../../components/DisclaimerStatic.astro';
import NavIsland from '../../islands/NavIsland.jsx';
import PriceIsland from '../../islands/PriceIsland.jsx';
import FooterStatic from '../../components/FooterStatic.astro';
import { NON_EN_LANGS, LANGS, getDict } from '../../lib/i18n.js';

import '@react/components/Nav.css';

export function getStaticPaths() {
    return NON_EN_LANGS.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = await getDict(lang);
const dir = LANGS[lang]?.dir || 'ltr';
---
<Base
    title={`${t.price.title} — UR`}
    description={t.price.intro}
    lang={lang}
    dir={dir}
>
    <!-- RSS autodiscovery: browsers and feed readers pick /price.rss up
         straight from this page. -->
    <link
        slot="head"
        rel="alternate"
        type="application/rss+xml"
        title="UR usage cost"
        href="/price.rss"
    />

    <div class="app">
        <DisclaimerStatic />
        <NavIsland activeRoute="price" lang={lang} client:load />

        <main class="section-page">
            <PriceIsland lang={lang} client:load />
        </main>

        <FooterStatic t={t} lang={lang} />
    </div>
</Base>
