---
import Base from '../../layouts/Base.astro';
import DisclaimerStatic from '../../components/DisclaimerStatic.astro';
import Section from '../../components/Section.astro';
import WhitepaperClauses from '../../components/WhitepaperClauses.astro';
import FooterStatic from '../../components/FooterStatic.astro';
import HeroIsland from '../../islands/HeroIsland.jsx';
import { NON_EN_LANGS, LANGS, getDict } from '../../lib/i18n.js';

export function getStaticPaths() {
    return NON_EN_LANGS.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = await getDict(lang);
const dir = LANGS[lang]?.dir || 'ltr';
---
<Base title={`$UR — ${t.nav.tagline}`} lang={lang} dir={dir}>
    <div class="app">
        <DisclaimerStatic />
        <HeroIsland client:load />

        <main>
            <Section id="whitepaper" eyebrow={t.whitepaper.eyebrow} title={t.whitepaper.title} variant="whitepaper">
                <WhitepaperClauses clauses={t.whitepaper.clauses} />
            </Section>
        </main>

        <FooterStatic t={t} lang={lang} />
    </div>
</Base>
