---
import Base from '../../layouts/Base.astro';
import DisclaimerStatic from '../../components/DisclaimerStatic.astro';
import NavIsland from '../../islands/NavIsland.jsx';
import Section from '../../components/Section.astro';
import CardGrid from '../../components/CardGrid.astro';
import FooterStatic from '../../components/FooterStatic.astro';
import NetworkDiagram from '@react/components/NetworkDiagram.jsx';
import MinerSim from '@react/components/MinerSim.jsx';
import ValidatorSim from '@react/components/ValidatorSim.jsx';
import OperatorsDirectoryIsland from '../../islands/OperatorsDirectoryIsland.jsx';
import { ResearchCompetition, ResearchCardGrid, ResearchFoot } from '@react/components/ResearchExtras.jsx';
import { CommunityFoot } from '@react/components/CommunityFoot.jsx';
import en from '@react/i18n/en.js';
import { NON_EN_LANGS, LANGS, SECTION_ROUTES, getDict } from '../../lib/i18n.js';

import '@react/components/Nav.css';

const ROLE_SECTIONS = ['operators', 'miners', 'validators'];

export function getStaticPaths() {
    const paths = [];
    for (const lang of NON_EN_LANGS) {
        for (const section of SECTION_ROUTES) {
            paths.push({ params: { lang, section } });
        }
    }
    return paths;
}

const { lang, section } = Astro.params;
const t = await getDict(lang);
const dir = LANGS[lang]?.dir || 'ltr';
const sectionData = t[section] || en[section];
const items = sectionData.roles || sectionData.items || sectionData.papers || [];
const showDiagram = ROLE_SECTIONS.includes(section);
---
<Base
    title={`${sectionData.title} — UR`}
    description={sectionData.intro}
    lang={lang}
    dir={dir}
>
    <div class="app">
        <DisclaimerStatic />
        <NavIsland activeRoute={section} lang={lang} client:load />

        <main class="section-page">
            <Section id={section} eyebrow={sectionData.eyebrow} title={sectionData.title}>
                {section === 'research' && <ResearchCompetition t={t} />}
                <p>{sectionData.intro}</p>
                {showDiagram && <NetworkDiagram client:load active={section} lang={lang} ctaLabel={sectionData.cta} />}
                {section === 'research'
                    ? <ResearchCardGrid t={t} />
                    : <CardGrid items={items} />}
                {section === 'operators' && <OperatorsDirectoryIsland lang={lang} client:visible />}
                {section === 'miners' && <MinerSim client:visible />}
                {section === 'validators' && <ValidatorSim client:visible />}
                {section === 'research' && <ResearchFoot t={t} />}
                {section === 'community' && <CommunityFoot t={t} />}
            </Section>
        </main>

        <FooterStatic t={t} lang={lang} />
    </div>
</Base>
