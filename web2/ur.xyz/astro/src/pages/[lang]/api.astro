---
import Base from '../../layouts/Base.astro';
import ApiIsland from '../../islands/ApiIsland.jsx';
import { NON_EN_LANGS, LANGS } from '../../lib/i18n.js';

export function getStaticPaths() {
    return NON_EN_LANGS.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const dir = LANGS[lang]?.dir || 'ltr';
---
<Base title="API Reference — UR" lang={lang} dir={dir}>
    <ApiIsland activeRoute="api" lang={lang} client:load />
</Base>
