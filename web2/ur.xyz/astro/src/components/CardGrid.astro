---
/**
 * Renders a card grid from an array of role/paper objects.
 * Each item: { tag, title, body, href?, linkLabel?, soon?, button? }
 *   soon   — small "coming soon" chip in place of a link
 *   button — pill button; disabled look until button.href exists
 */
interface Props {
    items: Array<{
        tag: string;
        title: string;
        body: string;
        href?: string;
        linkLabel?: string;
        soon?: string;
        button?: { label: string; href?: string };
    }>;
}

const { items } = Astro.props;
---
<div class="card-grid">
    {items.map(r => (
        <div class="card">
            <div class="card-eyebrow">{r.tag}</div>
            <h3 class="card-title">{r.title}</h3>
            <p class="card-body">{r.body}</p>
            {r.href && (
                <a href={r.href} class="card-link" target="_blank" rel="noopener noreferrer">
                    {r.linkLabel}
                </a>
            )}
            {r.soon && <span class="card-soon">{r.soon}</span>}
            {r.button && (
                r.button.href
                    ? <a href={r.button.href} class="card-button" target="_blank" rel="noopener noreferrer">{r.button.label}</a>
                    : <span class="card-button is-disabled">{r.button.label}</span>
            )}
        </div>
    ))}
</div>
