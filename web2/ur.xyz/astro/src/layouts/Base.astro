---
import '@react/App.css';

interface Props {
    title: string;
    description?: string;
    lang?: string;
    dir?: string;
}

const {
    title,
    description = '$UR — Own your privacy. Own your network.',
    lang = 'en',
    dir = 'ltr',
} = Astro.props;
---
<!doctype html>
<html lang={lang} dir={dir}>
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#101010" />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/ur.png" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="128x128" href="/favicon-128.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <link rel="preload" href="/PPNeueMontreal-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/PPNeueBit-Bold.woff2" as="font" type="font/woff2" crossorigin />

    <style is:global>
        @font-face {
            font-family: 'PPNeueMontreal';
            src: url('/PPNeueMontreal-Regular.woff2') format('woff2');
            font-weight: 400;
            font-style: normal;
            font-display: swap;
        }
        @font-face {
            font-family: 'PPNeueBit';
            src: url('/PPNeueBit-Bold.woff2') format('woff2');
            font-weight: 700;
            font-style: normal;
            font-display: swap;
        }
    </style>

    <title>{title}</title>
</head>
<body>
    <!-- Static site: navigation should do full page loads, not pushState -->
    <script is:inline>window.__ASTRO_STATIC__ = true;</script>
    <div id="root">
        <slot />
    </div>
</body>
</html>
